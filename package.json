{
  "name": "@polis/theme-mantine",
  "version": "0.2.0",
  "description": "Card Collecting theme for Polis-family apps (SCSS variables, fonts, base elements, responsive helpers, Mantine theme overrides).",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./theme": "./src/theme.ts",
    "./styles/*": "./src/styles/*",
    "./styles/main": "./src/styles/main.scss",
    "./styles/variables": "./src/styles/variables.scss",
    "./styles/fonts": "./src/styles/fonts.scss",
    "./styles/elements": "./src/styles/elements.scss",
    "./styles/responsive": "./src/styles/responsive.scss"
  },
  "files": [
    "src"
  ],
  "peerDependencies": {
    "@mantine/core": ">=7",
    "@polis/react": "github:PomeloProductions/polis-react",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "@polis/react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "scripts": {
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@mantine/core": "^7.17.8",
    "@polis/react": "github:PomeloProductions/polis-react",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.20.0"
  }
}
