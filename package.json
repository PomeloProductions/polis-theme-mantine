{
  "name": "@polis/theme-cc",
  "version": "0.1.0",
  "description": "Card Collecting theme for Polis-family apps (SCSS variables, fonts, base elements, responsive helpers, Mantine theme overrides).",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./theme": "./src/theme.ts",
    "./styles/*": "./src/styles/*",
    "./styles/main": "./src/styles/main.scss",
    "./styles/variables": "./src/styles/variables.scss",
    "./styles/fonts": "./src/styles/fonts.scss",
    "./styles/elements": "./src/styles/elements.scss",
    "./styles/responsive": "./src/styles/responsive.scss"
  },
  "files": [
    "src"
  ],
  "peerDependencies": {
    "@mantine/core": ">=7",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mantine/core": "^7.17.8",
    "typescript": "^5.8.3"
  }
}
